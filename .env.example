# atlas — environment configuration (copy to .env; NEVER commit real secrets)

# --- LLM (Claude) -----------------------------------------------------------
# Optional for M1: if unset, the planner falls back to a deterministic heuristic
# so the demo and tests run fully offline.
ANTHROPIC_API_KEY=
ATLAS_MODEL=claude-opus-4-8

# --- Observability (LangSmith) ----------------------------------------------
# Tracing turns on automatically when these are set — no code changes needed.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=atlas

# --- Persistence ------------------------------------------------------------
# Precedence: DATABASE_URL (Postgres) > ATLAS_SQLITE_PATH (SQLite) > in-memory.
# Postgres (M2.1) gives durable checkpoints + a hash-chained audit log that
# survive restarts. Start a local one with: docker compose up -d
#
# Required for M4.1 live email send: the audit log must be durable so
# has_executed(action_id) survives restarts (SQLite/in-memory audit is not enough).
ATLAS_SQLITE_PATH=
DATABASE_URL=
# Example: DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas
# Neon (managed Postgres + pgvector) example:
# DATABASE_URL=postgresql://<user>:<pw>@<endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require

# --- Knowledge embeddings (M4.6 — pgvector semantic retrieval) --------------
# With DATABASE_URL set, the KG retrieves with hybrid full-text + vector search. When VOYAGE_API_KEY
# is present, entities + queries are embedded with Voyage AI; otherwise a deterministic offline
# embedder is used (dev/CI stays hermetic — no API cost). The model and dim MUST agree (voyage-3 =>
# 1024). pgvector is enabled automatically by the KG's setup() (CREATE EXTENSION IF NOT EXISTS vector).
VOYAGE_API_KEY=
ATLAS_EMBEDDING_MODEL=voyage-3
ATLAS_EMBEDDING_DIM=1024

# --- Knowledge extraction (M4.5 — LLM entity/relation extraction) ------------
# When ATLAS_KG_EXTRACTION_ENABLED=true AND OPENROUTER_API_KEY is set, ingestion asks an LLM (via
# OpenRouter — primary model + comma-separated fallback chain) to extract typed concept entities
# (person/project/org/concept) and relations from each document, written alongside the chunks. The
# model never sets authorization — scope/ACL are always resolved server-side. Leave the flag false
# (default) for a deterministic, hermetic, zero-cost write path identical to M4.4. Caps bound how much
# untrusted model output is persisted per document.
OPENROUTER_API_KEY=
ATLAS_KG_EXTRACTION_ENABLED=false
ATLAS_EXTRACTION_MODEL=anthropic/claude-3.5-haiku
ATLAS_EXTRACTION_FALLBACK_MODELS=
ATLAS_EXTRACTION_MAX_ENTITIES=64
ATLAS_EXTRACTION_MAX_RELATIONS=128

# --- Interface (M3.2 FastAPI) -----------------------------------------------
# Dev server bind address (scripts/run_api.py).
ATLAS_API_HOST=127.0.0.1
ATLAS_API_PORT=8000
# Identity headers the DEV header shim reads (used only when OIDC below is NOT configured).
# SECURITY: DEV / TRUSTED-NETWORK ONLY — these headers are trusted blindly, so the API must sit
# behind a reverse proxy that authenticates the caller and SETS these headers. Configure OIDC for
# any real deployment. Changing the names requires a coordinated change at that proxy/ingress.
ATLAS_API_USER_HEADER=X-Atlas-User-Id
ATLAS_API_ROLES_HEADER=X-Atlas-Roles
ATLAS_API_ORG_HEADER=X-Atlas-Org
# Dev header shim only — required for OAuth connect when OIDC is not configured.
ATLAS_API_EMAIL_HEADER=X-Atlas-Email

# --- Authentication (M3.3 OIDC) ---------------------------------------------
# Set ALL THREE (issuer + audience + jwks_uri) to enable verified bearer-JWT auth; leave blank to
# use the dev header shim above. Use HTTPS URLs in production. See docs/guides/AUTH.md (Auth0/Okta/Clerk).
ATLAS_OIDC_ISSUER=
ATLAS_OIDC_AUDIENCE=
ATLAS_OIDC_JWKS_URI=
# Optional claim-name overrides (defaults shown) + clock-skew tolerance (seconds).
ATLAS_OIDC_USER_CLAIM=sub
ATLAS_OIDC_ROLES_CLAIM=roles
ATLAS_OIDC_ORG_CLAIM=org_id
# Required for OAuth provider binding — IdP must emit this claim in bearer JWTs.
ATLAS_OIDC_EMAIL_CLAIM=email
ATLAS_OIDC_LEEWAY=60
# Dev/integration only: allow non-localhost http:// issuer/JWKS URLs (default false).
ATLAS_OIDC_ALLOW_INSECURE_HTTP=false

# --- Rate limiting (M3.6 — per-principal, Upstash) --------------------------
# Throttles /chat and /approve per principal (per client IP for anonymous). Limiting is ON only when
# enabled AND both Upstash REST creds below are set; otherwise the interface is unthrottled
# (fail-open) — the dev/CI default. The token is a secret: NEVER commit a real value.
ATLAS_RATE_LIMIT_ENABLED=true
ATLAS_RATE_LIMIT_REQUESTS=60
ATLAS_RATE_LIMIT_WINDOW_SECONDS=60
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Authorization / Policy store (M3.4) ------------------------------------
# Role->permission mapping is in-memory (defaults) unless DATABASE_URL (above) is set, in which case
# it is the durable Postgres `atlas_role_permissions` table. A FRESH table is EMPTY = deny-all; seed
# it explicitly (no auto-seed):  uv run python scripts/manage_policy.py seed   (see docs/guides/AUTH.md)

# --- Email (M4.1 — Resend transactional send) -------------------------------
# Live send requires ALL THREE: DATABASE_URL (above) + RESEND_API_KEY + ATLAS_EMAIL_FROM.
# Resend creds alone (or SQLite-only persistence) leave send_email fail-closed after approval.
# Demos/tests use offline_registry() with a fake sender — no network.
RESEND_API_KEY=
ATLAS_EMAIL_FROM=
# Set to 1 only when intentionally running the live Resend integration test.
ATLAS_EMAIL_LIVE_TEST=

# --- Slack (M4.2 — managed bot post) ----------------------------------------
# Live post requires BOTH: DATABASE_URL (above) + SLACK_BOT_TOKEN.
# Token alone (or SQLite-only persistence) leave slack_post fail-closed after approval.
# Demos/tests use offline_registry() with a fake sender — no network.
SLACK_BOT_TOKEN=
# Channel ID or name for the opt-in live integration test (e.g. #general or C01234567).
ATLAS_SLACK_CHANNEL=
# Set to 1 only when intentionally running the live Slack integration test.
ATLAS_SLACK_LIVE_TEST=

# --- Credential vault (M4.3 — HashiCorp Vault KV v2) ------------------------
# Per-user OAuth tokens are stored in Vault when VAULT_ADDR and auth are set.
# Local dev: docker compose up -d vault
VAULT_ADDR=
VAULT_TOKEN=
# KV v2 mount path (Settings default: secret)
VAULT_MOUNT=
VAULT_NAMESPACE=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# --- Outbound OAuth (M4.3 — per-user integrations) --------------------------
# Gmail send + Google Calendar require all three Google vars; Slack user post requires all three Slack vars.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI=
ATLAS_OAUTH_SUCCESS_URL=
# Required when Google/Slack OAuth client creds are set (openssl rand -base64 32).
ATLAS_OAUTH_STATE_SECRET=
# Dev/test only: allow OAuth without ATLAS_OAUTH_STATE_SECRET (never use in production).
ATLAS_OAUTH_ALLOW_INSECURE_STATE=false
